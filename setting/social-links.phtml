<?php
/* Load the streaming columns directly from DB so they appear in the form even if
   WoWonder's $wo['setting'] query doesn't include them */
global $db;
$__streaming_cols = ['twitch','kick','rumble','tiktok','discord','steam','facebook_gaming','trovo','dlive'];
$__streaming_data = [];
if (!empty($wo['setting']['user_id'])) {
    try {
        $__row = $db->where('user_id', $wo['setting']['user_id'])->getOne('Wo_Users', implode(',', $__streaming_cols));
        if ($__row) {
            foreach ($__streaming_cols as $__col) {
                $__streaming_data[$__col] = $__row[$__col] ?? '';
            }
        }
    } catch (Exception $__e) {
        foreach ($__streaming_cols as $__col) { $__streaming_data[$__col] = ''; }
    }
}
/* Merge into $wo['setting'] so form values load correctly */
foreach ($__streaming_data as $__k => $__v) {
    $wo['setting'][$__k] = $__v;
}

/* Streaming fields are now saved via onglitch_save.phtml endpoint */
