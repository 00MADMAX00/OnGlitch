<script type="text/javascript">
$(function() {
  $('form.setting-profile-form').on('submit', function(e) {
    e.preventDefault();
    var $form = $(this);
    $form.find('.add_wow_loader').addClass('btn-loading');

    /* Step 1: Save streaming/gaming fields via onglitch_save endpoint (direct DB update) */
    var streamingData = {
      action:          'save_streaming',
      url:             '?link1=onglitch_save',
      twitch:          $form.find('[name="twitch"]').val(),
      kick:            $form.find('[name="kick"]').val(),
      rumble:          $form.find('[name="rumble"]').val(),
      tiktok:          $form.find('[name="tiktok"]').val(),
      discord:         $form.find('[name="discord"]').val(),
      steam:           $form.find('[name="steam"]').val(),
      facebook_gaming: $form.find('[name="facebook_gaming"]').val(),
      trovo:           $form.find('[name="trovo"]').val(),
      dlive:           $form.find('[name="dlive"]').val()
    };
    /* Use ajax_loading.php which loads onglitch_save.phtml — does direct $db->update() */
    $.post(Wo_Ajax_Requests_Filee() + '?link1=onglitch_save', streamingData);

    /* Step 2: Save standard social fields (facebook, twitter, vk, etc.) via WoWonder */
    $.post(Wo_Ajax_Requests_File() + '?f=update_socialinks_setting', $form.serialize(), function(data) {
      scrollToTop();
      if (data.status == 200) {
        $('.setting-profile-alert').html('<div class="alert alert-success">' + data.message + '</div>');
        $('.alert-success').fadeIn('fast', function() {
          $(this).delay(2500).slideUp(500, function() { $(this).remove(); });
        });
      } else if (data.errors) {
        var errors = data.errors.join("<br>");
        $('.setting-profile-alert').html('<div class="alert alert-danger">' + errors + '</div>');
        $('.alert-danger').fadeIn(300);
      }
      $form.find('.add_wow_loader').removeClass('btn-loading');
    });
  });
});
</script>