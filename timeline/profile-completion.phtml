	<script>
	jQuery(document).ready(function($) {
		$("#add-profile-avatar").click(function(event) {
			$('.profile-avatar-changer').find('input').trigger('click');
		});

		/* Check BOTH server-side setting AND localStorage for cross-device support */
		var _pcKey = 'wo_hide_pc_<?php echo $wo['user']['id']; ?>';
		var _pcHidden = localStorage.getItem(_pcKey) === '1' || '<?php echo !empty($wo['user']['hide_profile_completion']) ? "1" : "0"; ?>' === '1';
		if (_pcHidden) {
			$('#wo-profile-completion-wrap').hide();
			$('#wo-hide-profile-completion').prop('checked', true);
		}
	});

	function woToggleProfileCompletion(checkbox) {
		var key = 'wo_hide_pc_<?php echo $wo['user']['id']; ?>';
		var action = checkbox.checked ? 1 : 0;
		/* Save to localStorage for instant cross-tab response */
		if (action) { localStorage.setItem(key, '1'); } else { localStorage.removeItem(key); }
		if (action) {
			jQuery('#wo-profile-completion-wrap').slideUp(300);
		} else {
			jQuery('#wo-profile-completion-wrap').slideDown(300);
		}
		/* Save server-side: POST to ajax_loading.php with the timeline URL so WoWonder
		   loads the timeline/profile-completion template which handles wo_pc_action */
		var _pcUrl = typeof Wo_Ajax_Requests_Filee === 'function'
			? Wo_Ajax_Requests_Filee() + '?link1=timeline&u=<?php echo $wo['user']['username']; ?>'
			: window.location.href;
		jQuery.post(_pcUrl, { wo_pc_action: action, url: '?link1=timeline&u=<?php echo $wo['user']['username']; ?>' });
	}

	new CircleProgress('.progresss', {
		max: 100,
		value: <?php echo array_sum($wo['pr_complition']); ?>,
		textFormat: 'percent',
	});
	</script>
