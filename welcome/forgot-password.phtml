<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Forgot Password | GAMEZONE</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://unpkg.com/lucide@latest"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Rajdhani:wght@400;500;600;700&family=Orbitron:wght@400;700;900&family=Inter:wght@300;400;500;600&display=swap');
        :root{--purple:#a855f7;--pink:#ec4899;--bg:#05050f;--card-bg:rgba(10,8,25,0.75);}
        *{box-sizing:border-box;margin:0;padding:0;}
        body{background:var(--bg);color:white;font-family:'Inter',sans-serif;min-height:100vh;overflow-x:hidden;}
        #gz-star-field{position:fixed;inset:0;z-index:1;pointer-events:none;}
        .gz-star{position:absolute;background:white;border-radius:50%;}
        #gz-spaceship{position:fixed;left:50%;transform:translateX(-50%);z-index:2;pointer-events:none;top:-300px;}
        .gz-ship-inner{position:relative;display:flex;flex-direction:column;align-items:center;}
        .gz-trail-wrap{position:absolute;bottom:100%;left:50%;transform:translateX(-50%);width:160px;height:1600px;}
        .gz-trail-nebula{position:absolute;bottom:0;left:50%;transform:translateX(-50%);width:140px;height:100%;background:linear-gradient(to top,rgba(59,130,246,.3) 0%,rgba(168,85,247,.15) 20%,transparent 80%);filter:blur(30px);border-radius:9999px;animation:gz-breathe 2.4s ease-in-out infinite;}
        .gz-trail-mid{position:absolute;bottom:0;left:50%;transform:translateX(-50%);width:36px;height:85%;background:linear-gradient(to top,rgba(147,197,253,.55) 0%,rgba(168,85,247,.25) 25%,transparent 80%);filter:blur(8px);border-radius:9999px;animation:gz-breathe 1.8s ease-in-out infinite reverse;}
        .gz-trail-core{position:absolute;bottom:0;left:50%;transform:translateX(-50%);width:3px;height:70%;background:linear-gradient(to top,rgba(255,255,255,.9),rgba(191,219,254,.6),transparent);filter:blur(1px);border-radius:9999px;}
        @keyframes gz-breathe{0%,100%{opacity:1;transform:translateX(-50%) scaleX(1)}50%{opacity:.6;transform:translateX(-50%) scaleX(.8)}}
        .gz-jet-wrap{position:absolute;bottom:100%;left:50%;transform:translateX(-50%);width:60px;height:120px;}
        .gz-jet-halo{position:absolute;bottom:0;left:50%;transform:translateX(-50%);width:55px;height:100px;background:radial-gradient(ellipse at 50% 100%,rgba(59,130,246,.7) 0%,rgba(168,85,247,.4) 35%,transparent 75%);filter:blur(12px);border-radius:9999px 9999px 0 0;animation:gz-fd .18s ease-in-out infinite;}
        .gz-jet-flame{position:absolute;bottom:0;left:50%;transform:translateX(-50%);width:22px;height:75px;background:radial-gradient(ellipse at 50% 100%,#fff 0%,#93c5fd 15%,#3b82f6 40%,rgba(168,85,247,.6) 65%,transparent 90%);filter:blur(2px);border-radius:9999px 9999px 0 0;animation:gz-fm .12s ease-in-out infinite;}
        .gz-jet-core{position:absolute;bottom:0;left:50%;transform:translateX(-50%);width:7px;height:30px;background:linear-gradient(to top,#fff,#bfdbfe,transparent);filter:blur(1px);border-radius:9999px;}
        @keyframes gz-fd{0%,100%{transform:translateX(-50%) scaleX(1) scaleY(1)}25%{transform:translateX(-50%) scaleX(1.1) scaleY(.95)}75%{transform:translateX(-50%) scaleX(.9) scaleY(1.05)}}
        @keyframes gz-fm{0%,100%{transform:translateX(-50%) scaleX(1) scaleY(1)}33%{transform:translateX(-50%) scaleX(1.15) scaleY(.92)}66%{transform:translateX(-50%) scaleX(.88) scaleY(1.08)}}
        #gz-nav{position:fixed;top:0;left:0;right:0;z-index:1000;display:flex;justify-content:space-between;align-items:center;padding:16px 24px;}
        .gz-back-btn{display:flex;align-items:center;gap:8px;background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.1);border-radius:12px;padding:8px 16px;font-family:'Rajdhani',sans-serif;font-weight:700;font-size:13px;letter-spacing:.1em;text-transform:uppercase;color:white;text-decoration:none;transition:all .2s;}
        .gz-back-btn:hover{background:rgba(168,85,247,.1);border-color:rgba(168,85,247,.3);}
        .gz-brand{font-family:'Orbitron',sans-serif;font-weight:900;font-size:18px;text-transform:uppercase;letter-spacing:.05em;}
        .gz-brand span{color:var(--purple);}
        .gz-main{position:relative;z-index:10;display:flex;flex-direction:column;align-items:center;padding:0 20px 60px;}
        .gz-card{position:relative;border-radius:18px;background:var(--card-bg);backdrop-filter:blur(24px);-webkit-backdrop-filter:blur(24px);border:1px solid rgba(168,85,247,.2);overflow:hidden;}
        .gz-card::before{content:'';position:absolute;inset:0;border-radius:inherit;padding:1.5px;background:linear-gradient(135deg,rgba(168,85,247,.8),rgba(236,72,153,.5),rgba(59,130,246,.6),rgba(168,85,247,.4));-webkit-mask:linear-gradient(#fff 0 0) content-box,linear-gradient(#fff 0 0);-webkit-mask-composite:xor;mask-composite:exclude;pointer-events:none;animation:gz-bs 6s linear infinite;}
        @keyframes gz-bs{0%{filter:hue-rotate(0deg)}100%{filter:hue-rotate(360deg)}}
        .gz-card-glow{position:absolute;top:-40%;left:-20%;width:60%;height:80%;background:radial-gradient(ellipse,rgba(168,85,247,.12) 0%,transparent 70%);pointer-events:none;}
        .gz-wrap{width:100%;max-width:520px;}
        .gz-body{padding:48px 52px;display:flex;flex-direction:column;align-items:center;}
        @media(max-width:600px){.gz-body{padding:32px 24px;}}
        .gz-icon-box{width:76px;height:76px;border-radius:18px;background:rgba(168,85,247,.12);border:1px solid rgba(168,85,247,.3);display:flex;align-items:center;justify-content:center;margin-bottom:28px;color:var(--purple);}
        .gz-heading{font-family:'Orbitron',sans-serif;font-weight:700;font-size:clamp(1.3rem,4vw,1.8rem);text-transform:uppercase;text-align:center;margin-bottom:8px;letter-spacing:.05em;}
        .gz-sub{font-size:13px;color:rgba(255,255,255,.4);text-align:center;margin-bottom:36px;line-height:1.6;}
        .gz-field{width:100%;margin-bottom:24px;}
        .gz-label{display:block;font-family:'Rajdhani',sans-serif;font-weight:700;font-size:11px;letter-spacing:.3em;text-transform:uppercase;color:rgba(255,255,255,.4);margin-bottom:8px;}
        .gz-input{width:100%;background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.1);border-radius:12px;padding:16px 20px;font-size:15px;color:white;outline:none;transition:border-color .2s,box-shadow .2s;font-family:'Inter',sans-serif;}
        .gz-input::placeholder{color:rgba(255,255,255,.25);} select.gz-input,select.gz-input option{background:#0d0b1e;color:white;}
        .gz-input:focus{border-color:rgba(168,85,247,.5);box-shadow:0 0 0 3px rgba(168,85,247,.08);}
        .gz-submit-btn{white-space:nowrap;width:100%;padding:18px;border:none;border-radius:12px;background:linear-gradient(135deg,var(--purple),var(--pink));background-size:200% 200%;animation:gz-bg 3s linear infinite;font-family:'Orbitron',sans-serif;font-weight:700;font-size:14px;letter-spacing:.15em;text-transform:uppercase;color:white;cursor:pointer;display:flex;align-items:center;justify-content:center;gap:10px;transition:transform .2s,box-shadow .2s;box-shadow:0 8px 32px rgba(168,85,247,.35);margin-bottom:20px;}
        @keyframes gz-bg{0%{background-position:0% 50%}50%{background-position:100% 50%}100%{background-position:0% 50%}}
        .gz-submit-btn:hover{transform:translateY(-2px);box-shadow:0 12px 40px rgba(168,85,247,.5);}
        .gz-alert{width:100%;padding:12px 16px;border-radius:10px;font-size:13px;margin-bottom:16px;display:none;}
        .gz-alert-danger{background:rgba(239,68,68,.15);border:1px solid rgba(239,68,68,.3);color:#fca5a5;}
        .gz-alert-success{background:rgba(34,197,94,.15);border:1px solid rgba(34,197,94,.3);color:#86efac;}
        .gz-signin-link{font-size:13px;color:rgba(255,255,255,.4);text-align:center;}
        .gz-signin-link a{color:var(--purple);text-decoration:none;}
        body, .wrapper, .login { background-image: none !important; }
    </style>
</head>
<body>

    <div style="position:fixed;inset:0;z-index:0;pointer-events:none;background:url('https://zlab.me/oo.jpeg') center/cover no-repeat;"></div>
    <div id="gz-star-field"></div>

    <div id="gz-spaceship">
        <div class="gz-ship-inner">
            <div class="gz-trail-wrap"><div class="gz-trail-nebula"></div><div class="gz-trail-mid"></div><div class="gz-trail-core"></div></div>
            <div class="gz-jet-wrap"><div class="gz-jet-halo"></div><div class="gz-jet-flame"></div><div class="gz-jet-core"></div></div>
            <img src="https://zlab.me/sp.png" alt="Spaceship" style="width:140px;position:relative;z-index:2;filter:drop-shadow(0 0 60px rgba(168,85,247,0.9));">
        </div>
    </div>

    <nav id="gz-nav">
        <a href="<?php echo $wo['config']['site_url']; ?>" class="gz-back-btn">
            <i data-lucide="arrow-left" style="width:16px;height:16px;"></i>
            <?php echo $wo['lang']['login_here'] ?? 'Back to Login'; ?>
        </a>
        
    </nav>

        <!-- ONGLITCH hero title - same as welcome page -->
    <div style="position:relative;z-index:10;text-align:center;padding-top:68px;padding-bottom:0;">
        <div style="font-family:'Orbitron',sans-serif;font-weight:900;font-size:clamp(4rem,12vw,9rem);letter-spacing:-0.02em;line-height:1;text-transform:uppercase;margin-bottom:16px;">
            <span style="color:#ffffff;">ON</span><span style="color:#a855f7;text-shadow:0 0 20px rgba(168,85,247,0.8),0 0 60px rgba(168,85,247,0.4);">GLITCH</span>
        </div>
        <p style="font-family:'Rajdhani',sans-serif;font-weight:600;font-size:14px;letter-spacing:0.4em;text-transform:uppercase;color:#67e8f9;margin-bottom:20px;text-shadow:0 0 20px rgba(6,182,212,0.5);">The Social Network for Gamers</p>
    </div>

<main class="gz-main">
        <div class="gz-wrap gz-card">
            <div class="gz-card-glow"></div>
            <div class="gz-body">
                <div class="gz-icon-box"><i data-lucide="key-round" style="width:36px;height:36px;"></i></div>
                <h2 class="gz-heading"><?php echo $wo['lang']['forgot_your_password'] ?? 'Forgot Password'; ?></h2>
                <p class="gz-sub">
                    <?php echo $wo['lang']['if_you_have_account'] ?? 'Remember your password?'; ?>
                    <a href="<?php echo $wo['config']['site_url']; ?>" style="color:var(--purple);text-decoration:none;">
                        <?php echo $wo['lang']['login_here'] ?? 'Sign in'; ?>
                    </a>
                </p>

                <form id="gz-forgot-form" method="post" style="width:100%;">
                    <div class="gz-alert gz-alert-danger errors"></div>

                    <div class="gz-field">
                        <label class="gz-label"><?php echo $wo['lang']['email'] ?? 'Email'; ?></label>
                        <input name="recoveremail" type="email"
                               placeholder="<?php echo $wo['lang']['email_address'] ?? 'your@email.com'; ?>"
                               class="gz-input" autofocus>
                    </div>

                    <?php if($wo['config']['reCaptcha'] == 1): ?>
                    <div style="margin-bottom:20px;">
                        <div class="g-recaptcha" data-sitekey="<?php echo $wo['config']['reCaptchaKey']; ?>"></div>
                    </div>
                    <?php endif; ?>

                    <button type="submit" class="gz-submit-btn add_wow_loader">
                        <i data-lucide="send" style="width:18px;height:18px;"></i>
                        <?php echo $wo['lang']['recover_password'] ?? 'Send Reset Link'; ?>
                    </button>

                    <p class="gz-signin-link">
                        <?php echo $wo['lang']['if_you_have_account'] ?? 'Remembered it?'; ?>
                        <a href="<?php echo $wo['config']['site_url']; ?>">
                            <?php echo $wo['lang']['login_here'] ?? 'Sign In'; ?>
                        </a>
                    </p>
                </form>
            </div>
        </div>
    </main>

    <script>
    lucide.createIcons();
    var sf=document.getElementById('gz-star-field');
    for(var i=0;i<60;i++){var s=document.createElement('div');s.className='gz-star';var sz=Math.random()*2+.5;s.style.cssText='width:'+sz+'px;height:'+sz+'px;left:'+Math.random()*100+'%;top:'+Math.random()*100+'%;opacity:'+(Math.random()*.6+.1)+';';sf.appendChild(s);gsap.to(s,{opacity:Math.random()*.15+.05,duration:Math.random()*3+1.5,repeat:-1,yoyo:true,ease:'sine.inOut',delay:Math.random()*3});}
    gsap.to('#gz-spaceship',{y:window.innerHeight+600,ease:'none'});

    var $ff=$('#gz-forgot-form');
    var $fs=$ff.find('.errors');
    $(function(){
        $ff.ajaxForm({
            url: Wo_Ajax_Requests_File()+'?f=recover',
            beforeSend:function(){$ff.find('button').attr('disabled',true);$ff.find('.add_wow_loader').addClass('btn-loading');},
            success:function(data){
                if(data.status==200){
                    $fs.show().removeClass('gz-alert-danger').addClass('gz-alert-success').html('<?php echo $wo['lang']['email_sent']; ?>');
                    $ff.find('.add_wow_loader').removeClass('btn-loading');
                } else {
                    $ff.find('button').attr('disabled',false);
                    $ff.find('.add_wow_loader').removeClass('btn-loading');
                    $fs.show().removeClass('gz-alert-success').addClass('gz-alert-danger').html(data.errors);
                }
            }
        });
    });
    </script>
</body>
</html>
