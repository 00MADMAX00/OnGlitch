<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>GAMEZONE | The Social Network for Gamers</title>

    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://unpkg.com/lucide@latest"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/ScrollTrigger.min.js"></script>

    <style>
        @import url('https://fonts.googleapis.com/css2?family=Rajdhani:wght@400;500;600;700&family=Orbitron:wght@400;700;900&family=Inter:wght@300;400;500;600&display=swap');

        :root {
            --purple: #a855f7;
            --purple-dark: #7c3aed;
            --pink: #ec4899;
            --blue: #3b82f6;
            --cyan: #06b6d4;
            --bg: #05050f;
            --card-bg: rgba(10, 8, 25, 0.75);
        }

        * { box-sizing: border-box; margin: 0; padding: 0; }
        html { scroll-behavior: smooth; }

        body {
            background-color: var(--bg);
            color: white;
            font-family: 'Inter', sans-serif;
            overflow-x: hidden;
            min-height: 100vh;
        }

        /* ===== STARS ===== */
        #gz-star-field { position: fixed; inset: 0; z-index: 1; pointer-events: none; }
        .gz-star { position: absolute; background: white; border-radius: 50%; }

        /* ===== SPACESHIP ===== */
        #gz-spaceship {
            position: fixed; left: 50%; transform: translateX(-50%);
            z-index: 2; pointer-events: none; top: -300px;
        }
        .gz-ship-inner { position: relative; display: flex; flex-direction: column; align-items: center; }

        .gz-trail-wrap { position: absolute; bottom: 100%; left: 50%; transform: translateX(-50%); width: 160px; height: 1600px; }
        .gz-trail-nebula { position: absolute; bottom: 0; left: 50%; transform: translateX(-50%); width: 140px; height: 100%; background: linear-gradient(to top, rgba(59,130,246,0.30) 0%, rgba(168,85,247,0.15) 20%, rgba(139,92,246,0.06) 50%, transparent 80%); filter: blur(30px); border-radius: 9999px; animation: gz-trail-breathe 2.4s ease-in-out infinite; }
        .gz-trail-mid { position: absolute; bottom: 0; left: 50%; transform: translateX(-50%); width: 36px; height: 85%; background: linear-gradient(to top, rgba(147,197,253,0.55) 0%, rgba(168,85,247,0.25) 25%, rgba(139,92,246,0.08) 55%, transparent 80%); filter: blur(8px); border-radius: 9999px; animation: gz-trail-breathe 1.8s ease-in-out infinite reverse; }
        .gz-trail-core { position: absolute; bottom: 0; left: 50%; transform: translateX(-50%); width: 3px; height: 70%; background: linear-gradient(to top, rgba(255,255,255,0.9) 0%, rgba(191,219,254,0.6) 20%, rgba(147,197,253,0.3) 50%, transparent 100%); filter: blur(1px); border-radius: 9999px; }

        @keyframes gz-trail-breathe { 0%,100%{opacity:1;transform:translateX(-50%) scaleX(1)} 50%{opacity:0.6;transform:translateX(-50%) scaleX(0.8)} }

        .gz-jet-wrap { position: absolute; bottom: 100%; left: 50%; transform: translateX(-50%); width: 60px; height: 120px; }
        .gz-jet-halo { position: absolute; bottom: 0; left: 50%; transform: translateX(-50%); width: 55px; height: 100px; background: radial-gradient(ellipse at 50% 100%, rgba(59,130,246,0.7) 0%, rgba(168,85,247,0.4) 35%, transparent 75%); filter: blur(12px); border-radius: 9999px 9999px 0 0; animation: gz-flame-dance 0.18s ease-in-out infinite; }
        .gz-jet-flame { position: absolute; bottom: 0; left: 50%; transform: translateX(-50%); width: 22px; height: 75px; background: radial-gradient(ellipse at 50% 100%, #ffffff 0%, #93c5fd 15%, #3b82f6 40%, rgba(168,85,247,0.6) 65%, transparent 90%); filter: blur(2px); border-radius: 9999px 9999px 0 0; animation: gz-flame-main 0.12s ease-in-out infinite; }
        .gz-jet-core { position: absolute; bottom: 0; left: 50%; transform: translateX(-50%); width: 7px; height: 30px; background: linear-gradient(to top, #ffffff, #bfdbfe, transparent); filter: blur(1px); border-radius: 9999px; animation: gz-flame-core 0.08s ease-in-out infinite; }

        @keyframes gz-flame-dance { 0%,100%{transform:translateX(-50%) scaleX(1) scaleY(1);opacity:0.9} 25%{transform:translateX(-50%) scaleX(1.1) scaleY(0.95);opacity:1} 75%{transform:translateX(-50%) scaleX(0.9) scaleY(1.05);opacity:0.8} }
        @keyframes gz-flame-main { 0%,100%{transform:translateX(-50%) scaleX(1) scaleY(1);opacity:1} 33%{transform:translateX(-50%) scaleX(1.15) scaleY(0.92);opacity:0.9} 66%{transform:translateX(-50%) scaleX(0.88) scaleY(1.08);opacity:1} }
        @keyframes gz-flame-core { 0%,100%{opacity:1;transform:translateX(-50%) scaleY(1)} 50%{opacity:0.75;transform:translateX(-50%) scaleY(0.9)} }

        /* ===== NAV ===== */
        #gz-nav { position: fixed; top: 0; left: 0; right: 0; z-index: 1000; display: flex; justify-content: flex-end; padding: 16px 24px; }
        .gz-lang-pill { display: flex; align-items: center; justify-content: center; width: 42px; height: 42px; background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.1); border-radius: 12px; cursor: pointer; transition: all 0.2s; text-decoration: none; color: white; }
        .gz-lang-pill:hover { background: rgba(168,85,247,0.15); border-color: rgba(168,85,247,0.4); }
        .gz-lang-pill img { width: 22px; height: 22px; object-fit: contain; }

        /* ===== CARDS ===== */
        .gz-card {
            position: relative; border-radius: 18px; background: var(--card-bg);
            backdrop-filter: blur(24px); -webkit-backdrop-filter: blur(24px);
            border: 1px solid rgba(168,85,247,0.2); overflow: hidden;
            transition: transform 0.3s ease, box-shadow 0.3s ease;
        }
        .gz-card::before {
            content: ''; position: absolute; inset: 0; border-radius: inherit; padding: 1.5px;
            background: linear-gradient(135deg, rgba(168,85,247,0.8), rgba(236,72,153,0.5), rgba(59,130,246,0.6), rgba(168,85,247,0.4));
            -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
            -webkit-mask-composite: xor; mask-composite: exclude; pointer-events: none;
            animation: gz-border-spin 6s linear infinite;
        }
        @keyframes gz-border-spin { 0%{filter:hue-rotate(0deg)} 100%{filter:hue-rotate(360deg)} }
        .gz-card:hover { transform: translateY(-4px); box-shadow: 0 20px 60px rgba(168,85,247,0.2), 0 0 0 1px rgba(168,85,247,0.15); }
        .gz-card-glow { position: absolute; top: -40%; left: -20%; width: 60%; height: 80%; background: radial-gradient(ellipse, rgba(168,85,247,0.12) 0%, transparent 70%); pointer-events: none; }

        /* ===== HERO ===== */
        #gz-hero { position: relative; z-index: 10; min-height: 100vh; display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 80px 20px 60px; }
        .gz-hero-title { font-family: 'Orbitron', sans-serif; font-weight: 900; font-size: clamp(4rem, 12vw, 9rem); text-align: center; letter-spacing: -0.02em; line-height: 1; text-transform: uppercase; margin-bottom: 16px; }
        .gz-hero-title .gz-white { color: #fff; }
        .gz-hero-title .gz-purple { color: var(--purple); text-shadow: 0 0 20px rgba(168,85,247,0.8), 0 0 60px rgba(168,85,247,0.4); }
        .gz-hero-sub { font-family: 'Rajdhani', sans-serif; font-weight: 600; font-size: 14px; letter-spacing: 0.4em; text-transform: uppercase; color: #67e8f9; margin-bottom: 60px; text-align: center; text-shadow: 0 0 20px rgba(6,182,212,0.5); }

        /* ===== LOGIN CARD ===== */
        .gz-login-wrap { width: 100%; max-width: 560px; }
        .gz-login-body { padding: 48px 52px; display: flex; flex-direction: column; align-items: center; }
        .gz-icon-box { width: 76px; height: 76px; border-radius: 18px; background: rgba(168,85,247,0.12); border: 1px solid rgba(168,85,247,0.3); display: flex; align-items: center; justify-content: center; margin-bottom: 28px; color: var(--purple); }
        .gz-login-heading { font-family: 'Orbitron', sans-serif; font-weight: 700; font-size: clamp(1.5rem,4vw,2rem); text-transform: uppercase; text-align: center; margin-bottom: 8px; letter-spacing: 0.05em; }
        .gz-login-sub { font-size: 13px; color: rgba(255,255,255,0.4); text-align: center; margin-bottom: 40px; }
        .gz-field { width: 100%; margin-bottom: 24px; }
        .gz-label { display: block; font-family: 'Rajdhani', sans-serif; font-weight: 700; font-size: 11px; letter-spacing: 0.3em; text-transform: uppercase; color: rgba(255,255,255,0.4); margin-bottom: 10px; }
        .gz-input { width: 100%; background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.1); border-radius: 12px; padding: 16px 20px; font-size: 15px; color: white; outline: none; transition: border-color 0.2s, box-shadow 0.2s; font-family: 'Inter', sans-serif; }
        .gz-input::placeholder { color: rgba(255,255,255,0.25); }
        .gz-input:focus { border-color: rgba(168,85,247,0.5); box-shadow: 0 0 0 3px rgba(168,85,247,0.08); }
        .gz-input-wrap { position: relative; }
        .gz-eye { position: absolute; right: 16px; top: 50%; transform: translateY(-50%); color: rgba(255,255,255,0.3); cursor: pointer; background: none; border: none; }
        .gz-remember-row { width: 100%; display: flex; align-items: center; justify-content: space-between; margin-bottom: 28px; }
        .gz-remember { display: flex; align-items: center; gap: 10px; font-size: 14px; color: rgba(255,255,255,0.5); cursor: pointer; }
        .gz-remember input[type=checkbox] {
            width: 18px; height: 18px; appearance: none; -webkit-appearance: none;
            background: rgba(255,255,255,0.06); border: 1.5px solid rgba(255,255,255,0.2);
            border-radius: 4px; cursor: pointer; position: relative; transition: all 0.2s; flex-shrink: 0;
        }
        .gz-remember input[type=checkbox]:checked {
            background: var(--purple); border-color: var(--purple);
            box-shadow: 0 0 10px rgba(168,85,247,0.5);
        }
        .gz-remember input[type=checkbox]:checked::after {
            content: ''; position: absolute; left: 4px; top: 1px;
            width: 6px; height: 10px;
            border: 2px solid white; border-top: none; border-left: none;
            transform: rotate(45deg);
        }
        .gz-forgot { font-size: 14px; color: var(--purple); text-decoration: none; transition: opacity 0.2s; }
        .gz-forgot:hover { opacity: 0.7; }
        .gz-signin-btn { width: 100%; padding: 18px; border: none; border-radius: 12px; background: linear-gradient(135deg, var(--purple), var(--pink)); background-size: 200% 200%; animation: gz-btn-grad 3s linear infinite; font-family: 'Orbitron', sans-serif; font-weight: 700; font-size: 13px; letter-spacing: 0.1em; text-transform: uppercase; color: white; cursor: pointer; display: flex; align-items: center; justify-content: center; gap: 8px; white-space: nowrap; transition: transform 0.2s, box-shadow 0.2s; box-shadow: 0 8px 32px rgba(168,85,247,0.35); margin-bottom: 24px; }
        @keyframes gz-btn-grad { 0%{background-position:0% 50%} 50%{background-position:100% 50%} 100%{background-position:0% 50%} }
        .gz-signin-btn:hover { transform: translateY(-2px); box-shadow: 0 12px 40px rgba(168,85,247,0.5); }
        .gz-signin-btn:active { transform: scale(0.98); }
        .gz-divider { width: 100%; display: flex; align-items: center; gap: 10px; font-size: 13px; letter-spacing: 0; color: rgba(255,255,255,0.45); font-family: 'Rajdhani', sans-serif; font-weight: 600; white-space: nowrap; }
        .gz-divider::before, .gz-divider::after { content: ''; flex: 1; height: 1px; background: rgba(255,255,255,0.08); }

        /* Social login buttons */
        .gz-social-btns { display: flex; flex-wrap: wrap; gap: 10px; width: 100%; margin-bottom: 28px; }
        .gz-social-btn { display: flex; align-items: center; gap: 8px; padding: 12px 18px; background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); border-radius: 10px; color: white; text-decoration: none; font-size: 13px; font-family: 'Rajdhani', sans-serif; font-weight: 600; transition: all 0.2s; flex: 1; justify-content: center; min-width: 140px; }
        .gz-social-btn:hover { background: rgba(255,255,255,0.1); border-color: rgba(168,85,247,0.4); }
        .gz-social-btn svg { width: 20px; height: 20px; }

        /* Error/success alerts */
        .gz-alert { width: 100%; padding: 12px 16px; border-radius: 10px; font-size: 13px; margin-bottom: 20px; display: none; }
        .gz-alert:not(:empty) { display: block; }
        .gz-alert-danger { background: rgba(239,68,68,0.15); border: 1px solid rgba(239,68,68,0.3); color: #fca5a5; }
        .gz-alert-success { background: rgba(34,197,94,0.15); border: 1px solid rgba(34,197,94,0.3); color: #86efac; }

        /* ===== SECTIONS ===== */
        .gz-section { position: relative; z-index: 10; padding: 100px 20px; max-width: 1200px; margin: 0 auto; }
        .gz-section-hdr { text-align: center; margin-bottom: 60px; }
        .gz-section-title { font-family: 'Orbitron', sans-serif; font-weight: 900; font-size: clamp(2.5rem,6vw,4.5rem); text-transform: uppercase; letter-spacing: -0.02em; line-height: 1.1; margin-bottom: 16px; }
        .gz-section-title .gz-acc-purple { color: var(--purple); text-shadow: 0 0 20px rgba(168,85,247,0.7), 0 0 50px rgba(168,85,247,0.3); }
        .gz-section-title .gz-acc-cyan { color: #67e8f9; text-shadow: 0 0 20px rgba(6,182,212,0.7); }
        .gz-section-title .gz-acc-white { color: #ffffff; }
        .gz-section-desc { font-family: 'Rajdhani', sans-serif; font-size: 14px; letter-spacing: 0.35em; text-transform: uppercase; color: #67e8f9; text-shadow: 0 0 16px rgba(6,182,212,0.4); }

        /* ===== GAMER GRID ===== */
        .gz-gamer-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; }
        @media(max-width:900px){.gz-gamer-grid{grid-template-columns:repeat(2,1fr)}}
        @media(max-width:600px){.gz-gamer-grid{grid-template-columns:1fr}}

        .gz-gamer-body { padding: 36px 24px; display: flex; flex-direction: column; align-items: center; text-align: center; }
        .gz-gamer-icon { position: relative; width: 72px; height: 72px; border-radius: 50%; display: flex; align-items: center; justify-content: center; margin-bottom: 8px; }
        .gz-gamer-icon.has-bg { background: rgba(168,85,247,0.15); }
        .gz-gamer-icon svg { width: 32px; height: 32px; stroke: white; stroke-width: 1.5; }
        /* For real user avatars from WoWonder */
        .gz-gamer-icon img { width: 72px; height: 72px; border-radius: 50%; object-fit: cover; border: 2px solid rgba(168,85,247,0.3); }
        .gz-status-dot { position: absolute; bottom: 4px; right: 4px; width: 10px; height: 10px; border-radius: 50%; border: 2px solid var(--bg); background: #22c55e; box-shadow: 0 0 8px #22c55e; }
        .gz-gamer-name { font-family: 'Orbitron', sans-serif; font-weight: 700; font-size: 15px; letter-spacing: 0.08em; text-transform: uppercase; margin-bottom: 4px; }
        .gz-gamer-status { font-family: 'Rajdhani', sans-serif; font-size: 13px; font-weight: 600; color: #22c55e; margin-bottom: 4px; }
        .gz-gamer-meta { font-size: 12px; color: rgba(255,255,255,0.3); margin-bottom: 24px; }
        .gz-follow-btn { width: 100%; padding: 12px; background: transparent; border: 1px solid rgba(168,85,247,0.3); border-radius: 10px; font-family: 'Orbitron', sans-serif; font-weight: 700; font-size: 11px; letter-spacing: 0.2em; text-transform: uppercase; color: white; cursor: pointer; transition: all 0.2s; text-decoration: none; display: block; text-align: center; }
        .gz-follow-btn:hover { background: rgba(168,85,247,0.15); border-color: rgba(168,85,247,0.6); box-shadow: 0 0 20px rgba(168,85,247,0.2); }

        /* ===== FEATURE GRID ===== */
        .gz-feature-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 20px; }
        @media(max-width:700px){.gz-feature-grid{grid-template-columns:1fr}}
        .gz-feature-body { padding: 36px 32px; }
        .gz-feature-icon { width: 60px; height: 60px; border-radius: 16px; background: rgba(168,85,247,0.12); border: 1px solid rgba(168,85,247,0.2); display: flex; align-items: center; justify-content: center; margin-bottom: 20px; color: var(--purple); }
        .gz-feature-icon svg { width: 26px; height: 26px; }
        .gz-feature-title { font-family: 'Orbitron', sans-serif; font-weight: 700; font-size: 13px; letter-spacing: 0.1em; text-transform: uppercase; margin-bottom: 10px; }
        .gz-feature-desc { font-size: 14px; color: rgba(255,255,255,0.45); line-height: 1.7; }

        /* ===== FOOTER ===== */
        .gz-footer { position: relative; z-index: 10; border-top: 1px solid rgba(255,255,255,0.06); padding: 48px 40px; display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 24px; max-width: 1200px; margin: 0 auto; }
        .gz-footer-logo { display: flex; align-items: center; gap: 12px; font-family: 'Orbitron', sans-serif; font-weight: 900; font-size: 22px; text-transform: uppercase; letter-spacing: 0.05em; color: white; }
        .gz-footer-copy { font-size: 10px; letter-spacing: 0.4em; text-transform: uppercase; color: rgba(255,255,255,0.18); font-family: 'Rajdhani', sans-serif; font-weight: 600; }

        /* WoWonder overrides - hide default elements we don't need */
        .lb-preloader, .chat-all-container { display: none !important; }
        .random_users { display: none; }

        /* Dark select dropdowns everywhere */
        select, select option { background: #0d0b1e !important; color: white !important; }

        /* Language modal - centred on screen, big, responsive */
        #select-language.in,
        #select-language.show { display: flex !important; align-items: center !important; justify-content: center !important; }
        #select-language .modal-dialog {
            max-width: min(90vw, 1060px) !important;
            width: 90vw !important;
            margin: auto !important;
            position: relative !important;
        }
        #select-language .modal-content {
            background: #07060f !important; color: white !important;
            border: 1px solid rgba(168,85,247,0.35) !important;
            border-radius: 20px !important; overflow: hidden !important;
            box-shadow: 0 0 80px rgba(168,85,247,0.3) !important;
        }
        #select-language .modal-header {
            background: rgba(168,85,247,0.1) !important;
            border-bottom: 1px solid rgba(168,85,247,0.2) !important;
            padding: 20px 28px !important; display: flex !important;
            align-items: center !important;
        }
        #select-language .modal-title, #select-language h4 {
            color: white !important; font-family: 'Orbitron', sans-serif !important;
            font-size: 15px !important; letter-spacing: 0.1em !important;
            text-transform: uppercase !important; flex: 1 !important;
        }
        #select-language .close {
            color: white !important; opacity: 0.6 !important;
            text-shadow: none !important; font-size: 28px !important;
        }
        #select-language .close:hover { opacity: 1 !important; }
        #select-language .modal-body {
            background: #07060f !important; padding: 0 !important;
            display: flex !important; min-height: 0 !important;
        }
        #select-language .gz-lang-side {
            width: 180px !important; min-width: 180px !important; flex-shrink: 0 !important;
            background: url('https://onglitch.com/images/side.jpg') center/cover no-repeat !important;
            border-right: 1px solid rgba(168,85,247,0.2) !important;
        }
        @media(max-width: 600px) {
            #select-language .gz-lang-side { display: none !important; }
        }
        #select-language .gz-lang-grid-wrap {
            flex: 1 !important; padding: 24px !important;
            overflow-y: auto !important; max-height: 72vh !important;
        }
        #select-language .gz-lang-grid {
            display: grid !important;
            grid-template-columns: repeat(4, 1fr) !important;
            gap: 10px !important;
        }
        @media(max-width: 700px) {
            #select-language .gz-lang-grid { grid-template-columns: repeat(3, 1fr) !important; }
        }
        @media(max-width: 480px) {
            #select-language .gz-lang-grid { grid-template-columns: repeat(2, 1fr) !important; }
        }
        #select-language .gz-lang-card {
            display: flex !important; align-items: center !important; gap: 8px !important;
            padding: 11px 14px !important;
            background: rgba(255,255,255,0.05) !important;
            border: 1px solid rgba(255,255,255,0.1) !important;
            border-radius: 10px !important; cursor: pointer !important;
            text-decoration: none !important; color: white !important;
            font-family: 'Rajdhani', sans-serif !important; font-weight: 600 !important;
            font-size: 13px !important; transition: all 0.2s !important;
            white-space: nowrap !important; overflow: hidden !important;
            text-overflow: ellipsis !important;
        }
        #select-language .gz-lang-card:hover {
            background: rgba(168,85,247,0.2) !important;
            border-color: rgba(168,85,247,0.5) !important;
            transform: translateY(-2px) !important;
            box-shadow: 0 4px 16px rgba(168,85,247,0.2) !important;
            color: white !important;
        }
        #select-language .gz-lang-card img {
            width: 24px !important; height: 16px !important;
            object-fit: cover !important; border-radius: 3px !important;
            flex-shrink: 0 !important;
        }

        /* Override WoWonder theme background */
        body, .wrapper, .login, .login_left_combo_parent { background-image: none !important; }
    </style>
</head>
<body>

    <!-- BG Image -->
    <div style="position:fixed;inset:0;z-index:0;pointer-events:none;background:url('https://zlab.me/oo.jpeg') center/cover no-repeat;"></div>

    <!-- Stars -->
    <div id="gz-star-field"></div>

    <!-- Spaceship -->
    <div id="gz-spaceship">
        <div class="gz-ship-inner">
            <div class="gz-trail-wrap">
                <div class="gz-trail-nebula"></div>
                <div class="gz-trail-mid"></div>
                <div class="gz-trail-core"></div>
            </div>
            <div class="gz-jet-wrap">
                <div class="gz-jet-halo"></div>
                <div class="gz-jet-flame"></div>
                <div class="gz-jet-core"></div>
            </div>
            <img src="https://zlab.me/sp.png" alt="Spaceship" style="width:140px;position:relative;z-index:2;filter:drop-shadow(0 0 60px rgba(168,85,247,0.9)) drop-shadow(0 0 30px rgba(59,130,246,0.5));">
        </div>
    </div>

    <!-- Nav - fixed always on top -->
    <nav id="gz-nav">
        <a href="javascript:void(0);" class="gz-lang-pill" data-toggle="modal" data-target="#select-language">
            <img src="https://onglitch.com/images/lg.png" alt="Language">
        </a>
