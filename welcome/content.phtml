    <script>
    // ===== INIT ICONS =====
    lucide.createIcons();

    // ===== PASSWORD TOGGLE =====
    function gzTogglePw() {
        var inp = document.getElementById('gz-password');
        var ico = document.getElementById('gz-eye-icon');
        if (inp.type === 'password') {
            inp.type = 'text';
            ico.setAttribute('data-lucide', 'eye-off');
        } else {
            inp.type = 'password';
            ico.setAttribute('data-lucide', 'eye');
        }
        lucide.createIcons();
    }

    // ===== LANGUAGE MODAL FULL REBUILD =====
    var gzFlagMap = {
        'arabic':'sa','bengali':'bd','chinese':'cn','croatian':'hr',
        'danish':'dk','dutch':'nl','english':'gb','filipino':'ph',
        'french':'fr','german':'de','hebrew':'il','hindi':'in',
        'indonesian':'id','italian':'it','japanese':'jp','korean':'kr',
        'persian':'ir','portuguese':'pt','portuguese (brazil)':'br',
        'russian':'ru','spanish':'es','swedish':'se','turkish':'tr',
        'urdu':'pk','vietnamese':'vn','hungarian':'hu','georgian':'ge',
        'greek':'gr','thai':'th','malay':'my','slovak':'sk','czech':'cz',
        'romanian':'ro','polish':'pl','norwegian':'no','finnish':'fi',
        'ukrainian':'ua','bulgarian':'bg','serbian':'rs','albanian':'al',
        'latvian':'lv','lithuanian':'lt','estonian':'ee','slovenian':'si',
        'swahili':'ke','afrikaans':'za','somali':'so','catalan':'es',
        'welsh':'gb','irish':'ie','basque':'es','galician':'es',
        'bosnian':'ba','macedonian':'mk','armenian':'am','azerbaijani':'az',
        'kazakh':'kz','uzbek':'uz','mongolian':'mn','tibetan':'cn',
        'khmer':'kh','burmese':'mm','tamil':'lk','telugu':'in',
        'kannada':'in','malayalam':'in','gujarati':'in','punjabi':'in',
        'nepali':'np','sinhala':'lk','lao':'la','pashto':'af'
    };

    function gzBuildLangModal() {
        var modal = document.getElementById('select-language');
        if (!modal) return;
        var body = modal.querySelector('.modal-body');
        if (!body) return;

        // Collect all existing language links from WoWonder
        var existingLinks = body.querySelectorAll('a');
        if (!existingLinks.length) return;
        if (body.querySelector('.gz-lang-grid')) return; // already built

        // Build language data from existing links
        var langs = [];
        var seen = {};
        existingLinks.forEach(function(a) {
            var txt = a.textContent.trim();
            var href = a.href || a.getAttribute('href') || '#';
            if (txt && !seen[txt.toLowerCase()]) {
                langs.push({name: txt, href: href});
                seen[txt.toLowerCase()] = true;
            }
        });

        // Add Hungarian and Georgian manually if not already present
        var extraLangs = [
            {name: 'Hungarian', code: 'hu'},
            {name: 'Georgian',  code: 'ka'}
        ];
        extraLangs.forEach(function(extra) {
            if (!seen[extra.name.toLowerCase()]) {
                // Link to WoWonder's language change URL
                langs.push({name: extra.name, href: '<?php echo $wo["config"]["site_url"]; ?>?lang=' + extra.code});
            }
        });

        // Sort alphabetically
        langs.sort(function(a,b){ return a.name.localeCompare(b.name); });

        // Clear and rebuild
        body.innerHTML = '';

        // Side image
        var side = document.createElement('div');
        side.className = 'gz-lang-side';
        body.appendChild(side);

        // Grid wrapper
        var wrap = document.createElement('div');
        wrap.className = 'gz-lang-grid-wrap';
        var grid = document.createElement('div');
        grid.className = 'gz-lang-grid';

        langs.forEach(function(lang) {
            var key = lang.name.toLowerCase();
            var flagCode = gzFlagMap[key] || null;

            var card = document.createElement('a');
            card.className = 'gz-lang-card';
            card.href = lang.href;

            if (flagCode) {
                var img = document.createElement('img');
                img.src = 'https://flagcdn.com/w40/' + flagCode + '.png';
                img.alt = lang.name;
                img.onerror = function(){ this.style.display='none'; };
                card.appendChild(img);
            } else {
                var span = document.createElement('span');
                span.textContent = '🌐';
                span.style.fontSize = '14px';
                card.appendChild(span);
            }

            var label = document.createElement('span');
            label.textContent = lang.name;
            card.appendChild(label);
            grid.appendChild(card);
        });

        wrap.appendChild(grid);
        body.appendChild(wrap);
    }

    // Run on modal open
    $(document).on('shown.bs.modal', '#select-language', function() {
        gzBuildLangModal();
    });

    // ===== STARS - soft slow twinkle =====
    var gzSF = document.getElementById('gz-star-field');
    for (var i = 0; i < 100; i++) {
        var s = document.createElement('div');
        s.className = 'gz-star';
        var sz = Math.random() * 2.2 + 0.4;
        var baseOpacity = Math.random() * 0.5 + 0.2;
        s.style.cssText = 'width:'+sz+'px;height:'+sz+'px;left:'+Math.random()*100+'%;top:'+Math.random()*100+'%;opacity:0;';
        gzSF.appendChild(s);
        // Fade in first, then twinkle softly
        gsap.to(s, {
            opacity: baseOpacity,
            duration: Math.random() * 3 + 2,
            delay: Math.random() * 4,
            ease: 'power1.out',
            onComplete: function(star, lo, hi) {
                gsap.to(star, {
                    opacity: lo,
                    duration: Math.random() * 4 + 3,
                    repeat: -1,
                    yoyo: true,
                    ease: 'sine.inOut',
                    delay: Math.random() * 2
                });
            }.bind(null, s, baseOpacity * 0.25, baseOpacity)
        });
    }

    // ===== SPACESHIP PARALLAX =====
    gsap.registerPlugin(ScrollTrigger);
    /* scrub:true (=1) gives tighter coupling to scroll position — eliminates jerkiness.
       will-change:transform tells browser to promote the element to its own GPU layer. */
    document.getElementById('gz-spaceship').style.willChange = 'transform';
    var shipTravel = window.innerHeight + 300 + 200;
    gsap.to('#gz-spaceship', {
        y: shipTravel, ease: 'none',
        scrollTrigger: { trigger: 'body', start: 'top top', end: 'bottom bottom', scrub: true }
    });

    // ===== CARD ENTRANCE - smooth float up =====
    gsap.utils.toArray('.gz-card').forEach(function(card, i) {
        gsap.fromTo(card,
            {opacity:0, y:40},
            {opacity:1, y:0, duration:1.2, delay:(i%3)*0.15, ease:'power2.out',
             scrollTrigger: {trigger:card, start:'top 95%', toggleActions:'play none none none'}}
        );
    });

    // ===== HERO ENTRANCE =====
    gsap.fromTo('.gz-hero-title', {opacity:0, y:-30}, {opacity:1, y:0, duration:1.2, ease:'power4.out', delay:0.2});
    gsap.fromTo('.gz-hero-sub', {opacity:0}, {opacity:1, duration:1, ease:'power2.out', delay:0.6});

    // ===== WoWonder LOGIN FORM AJAX =====
    var gzWorking = false;
    var $gzForm = $('#gz-login-form');
    var $gzState = $gzForm.find('.errors');

    <?php if($wo['config']['googleLogin'] != 0): ?>
    function handleCredentialResponse(response) {
        $.post(Wo_Ajax_Requests_File() + '?f=google_login', {id_token: response.credential}, function(data) {
            if (data.status == 200) {
                $gzState.addClass('gz-alert-success').html('<?php echo $wo['lang']['welcome_back']; ?>');
                setTimeout(function(){ window.location.href = data.location; }, 1000);
            } else {
                $gzState.addClass('gz-alert-danger').html(data.message);
            }
        });
    }
    window.onload = function() {
        google.accounts.id.initialize({
            client_id: "<?php echo $wo['config']['googleAppId']; ?>",
            callback: handleCredentialResponse
        });
        google.accounts.id.renderButton(document.getElementById("gz-google-btn"), {theme:"outline", size:"large"});
        google.accounts.id.prompt();
    };
    <?php endif; ?>

    $(function() {
        $gzForm.ajaxForm({
            url: Wo_Ajax_Requests_File() + '?f=login',
            beforeSend: function() {
                gzWorking = true;
                $gzForm.find('button[type=submit]').attr('disabled', true);
                $gzForm.find('.add_wow_loader').addClass('btn-loading');
            },
            success: function(data) {
                if (data.status == 200 || data.status == 600) {
                    $gzState.removeClass('gz-alert-danger').addClass('gz-alert-success');
                    $gzState.html('<?php echo $wo['lang']['welcome_back']; ?>');
                    $gzForm.find('.add_wow_loader').removeClass('btn-loading');
                    setTimeout(function(){ window.location.href = data.location; }, 1000);
                } else {
                    var errors = data.errors.join('<br>');
                    $gzForm.find('button[type=submit]').attr('disabled', false);
                    $gzForm.find('.add_wow_loader').removeClass('btn-loading');
                    $gzState.removeClass('gz-alert-success').addClass('gz-alert-danger').html(errors);
                }
                gzWorking = false;
            }
        });
    });
    </script>
